<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flight_Tracker_System.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Flight_Tracker_System.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Flight_Tracker_System.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Flight_Tracker_System">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Navigation bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="20,12,20,4">
            <Button Content="&#8592;" Command="{Binding GoBackCommand}"
                    IsEnabled="{Binding CanGoBack}"
                    ToolTip.Tip="Go back"
                    Width="36" Height="36" FontSize="16"/>
            <Button Content="&#8594;" Command="{Binding GoForwardCommand}"
                    IsEnabled="{Binding CanGoForward}"
                    ToolTip.Tip="Go forward"
                    Width="36" Height="36" FontSize="16"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Padding="20" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Border Background="{StaticResource SurfaceBackgroundBrush}" CornerRadius="14" Padding="20">
                <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                    <TabItem Header="Route Visualisation">
                        <views:RouteVisualisation DataContext="{Binding RouteVisualisationVM}"/>
                    </TabItem>
                    <TabItem Header="Flight Info">
                        <views:FlightInfo DataContext="{Binding FlightInfoVM}"/>
                    </TabItem>
                    <TabItem Header="Analytics">
                        <views:Analytics DataContext="{Binding AnalyticsVM}"/>
                    </TabItem>
                </TabControl>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
