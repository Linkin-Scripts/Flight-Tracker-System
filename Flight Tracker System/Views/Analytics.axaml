<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flight_Tracker_System.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="Flight_Tracker_System.Views.Analytics"
             x:DataType="vm:AnalyticsViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="40">

            <TextBlock Text="Top Airlines" FontSize="18"/>

            <lvc:CartesianChart Series="{Binding AirlineSeries}">
                <lvc:CartesianChart.XAxes>
                    <lvc:Axis Labels="{Binding AirlineLabels}" />
                </lvc:CartesianChart.XAxes>
            </lvc:CartesianChart>

            <TextBlock Text="Busiest Routes" FontSize="18"/>

            <lvc:CartesianChart Series="{Binding RouteSeries}">
                <lvc:CartesianChart.XAxes>
                    <lvc:Axis Labels="{Binding RouteLabels}" />
                </lvc:CartesianChart.XAxes>
            </lvc:CartesianChart>

            <TextBlock Text="Flights Per Day" FontSize="18"/>

            <lvc:CartesianChart Series="{Binding FlightsPerDaySeries}">
                <lvc:CartesianChart.XAxes>
                    <lvc:Axis Labels="{Binding DayLabels}" />
                </lvc:CartesianChart.XAxes>
            </lvc:CartesianChart>

        </StackPanel>
    </ScrollViewer>
</UserControl> 