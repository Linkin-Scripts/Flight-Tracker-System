<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flight_Tracker_System.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="Flight_Tracker_System.Views.Analytics"
             x:DataType="vm:AnalyticsViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="40">

            <TextBlock Text="Top Airlines" FontSize="18"/>
            <lvc:CartesianChart Series="{Binding AirlineSeries}" XAxes="{Binding AirlineXAxes}" Height="250"/>

            <TextBlock Text="Busiest Routes" FontSize="18"/>
            <lvc:CartesianChart Series="{Binding RouteSeries}" XAxes="{Binding RouteXAxes}" Height="250"/>

            <TextBlock Text="Flights Per Day" FontSize="18"/>
            <lvc:CartesianChart Series="{Binding FlightsPerDaySeries}" XAxes="{Binding DayXAxes}" Height="250"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
